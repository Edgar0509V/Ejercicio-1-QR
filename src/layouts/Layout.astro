---
import "../styles/global.css";
import logo from "../pages/img/favicon-32x32.png";
import QR from "../pages/img/image-qr-code.png"

---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href={logo.src} />
		<meta name="generator" content={Astro.generator} />
		<title>Qr Code</title>
	</head>
	<body class="bg-blue-100">

		<main class="flex min-h-screen items-center justify-center ">
		<section class="bg-white w-64 rounded-2xl p-4 shadow-lg text-center">
			<img src={QR.src} alt="QR Code" class="rounded-xl mb-4">
			<div class="px-2 pb-2">
				<h2 class="text-slate-900 font-bold text-lg mb-3">
					Improve your front-end skills by building projects
				</h2>
				<p class="text-slate-500 text-sm">
					Scan the QR code to visit Frontend Mentor and take your coding skills to the next level
				</p>
			</div>
		</section>
		</main>
		
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
